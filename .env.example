# LLM 配置
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-
LLM_MODEL=gpt-4o
# LLM_BASE_URL=

# Embedding 模型
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# 向量库配置
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./data/chroma
# QDRANT_URL=http://localhost:6333

# 检索参数
HYBRID_RRF_K=60
RERANK_TOP_K=50
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Cross-Encoder 模型
CROSS_ENCODER_MODEL=BAAI/bge-reranker-large

# 对话记忆
MEMORY_WINDOW_SIZE=3
ENABLE_SUMMARIZATION=true